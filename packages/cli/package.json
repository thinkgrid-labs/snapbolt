{
    "name": "@think-grid-labs/snapbolt-cli",
    "version": "0.1.3",
    "main": "index.js",
    "types": "index.d.ts",
    "napi": {
        "name": "snapbolt-cli",
        "triples": {
            "defaults": true,
            "additional": [
                "x86_64-apple-darwin",
                "aarch64-apple-darwin",
                "x86_64-unknown-linux-gnu",
                "x86_64-pc-windows-msvc"
            ]
        }
    },
    "scripts": {
        "build": "napi build --platform --release",
        "build:debug": "napi build --platform",
        "test": "node index.js"
    },
    "devDependencies": {
        "@napi-rs/cli": "^2.16.0"
    },
    "description": "CLI tool for @think-grid-labs/snapbolt",
    "keywords": [
        "cli",
        "image-optimization",
        "webp",
        "rust",
        "snapbolt"
    ],
    "author": "DennisP <dennis@thinkgrid-labs.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/ThinkGrid-Labs/snapbolt.git",
        "directory": "packages/cli"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "bin": {
        "snapbolt-cli": "./bin/cli.js"
    },
    "files": [
        "index.js",
        "index.d.ts",
        "*.node",
        "bin",
        "README.md"
    ],
    "engines": {
        "node": ">= 10"
    }
}