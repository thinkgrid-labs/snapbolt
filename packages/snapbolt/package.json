{
  "name": "@thinkgrid/snapbolt",
  "version": "0.2.1",
  "description": "Unified image optimization toolkit for the browser and React",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "pkg",
    "handler.js",
    "handler.d.ts",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js",
      "default": "./dist/image.js"
    },
    "./browser": {
      "types": "./pkg/snapbolt.d.ts",
      "import": "./pkg/snapbolt.js",
      "default": "./pkg/snapbolt.js"
    },
    "./handler": {
      "types": "./handler.d.ts",
      "default": "./handler.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:wasm && npm run build:ts",
    "build:wasm": "npx wasm-pack build --target web --out-dir pkg --release && rm pkg/.gitignore",
    "build:ts": "tsc",
    "test": "vitest"
  },
  "keywords": [
    "react",
    "react-component",
    "nextjs",
    "nextjs-component",
    "image-optimization",
    "wasm",
    "webp"
  ],
  "author": "DennisP <dennis@thinkgrid.dev>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "@thinkgrid/snapbolt-cli": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@thinkgrid/snapbolt-cli": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^8.0.0",
    "vitest": "^2.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/dom": "^10.0.0",
    "jsdom": "^25.0.0",
    "@types/node": "^20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkgrid-labs/snapbolt",
    "directory": "packages/snapbolt"
  },
  "publishConfig": {
    "access": "public"
  }
}
